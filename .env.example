GEELARK_BASE_URL=https://open.geelark.com
GEELARK_PUBLISH_PATH=/open/v1/rpa/task/instagramPubReels
GEELARK_BEARER_TOKEN=
GEELARK_APP_ID=
GEELARK_API_KEY=
GEELARK_CLOUD_PHONE_ID=

# Optional: if GeeLark has direct upload endpoint
GEELARK_UPLOAD_URL=
GEELARK_UPLOAD_FIELD=file
GEELARK_UPLOAD_RESULT_URL_FIELD=data.url

# Optional: Cloudinary upload fallback
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Optional: S3 presigned upload fallback
S3_PRESIGNED_UPLOAD_URL=
S3_PUBLIC_URL=

PUBLISH_RETRIES=3
PUBLISH_RETRY_DELAY_SEC=2

# Video upload transport (required for /publish)
VIDEO_SSH_HOST=local
VIDEO_SSH_PORT=22
VIDEO_SSH_USER=
VIDEO_SSH_KEY_PATH=
VIDEO_SSH_PASSWORD=
VIDEO_REMOTE_DIR=~/Desktop/my_videos
VIDEO_PUBLIC_BASE_URL=

UPLOAD_RETRIES=3
UPLOAD_RETRY_DELAY_SEC=2
